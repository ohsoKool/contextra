    "@sap/hana-client": "^2.28.20",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "groq-sdk": "^1.1.2",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9"
  },
  "cds": {
