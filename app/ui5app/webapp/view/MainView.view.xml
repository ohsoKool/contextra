<mvc:View
    controllerName="ui5app.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified"
    displayBlock="true">

    <Page id="_IDGenPage"
        showHeader="false">

        <content>

            <VBox id="_IDGenVBox"
                width="100%"
                alignItems="Center"
                justifyContent="Start"
                class="sapUiLargeMarginTop">

                <Panel id="_IDGenPanel1"
                    width="900px"
                    headerText="{i18n>appTitle}"
                    class="sapUiResponsiveMargin">

                    <VBox id="_IDGenVBox1" class="sapUiMediumMargin">

                        <unified:FileUploader
                            id="pdfUploader"
                            name="pdf"
                            uploadUrl="/upload"
                            fileType="pdf"
                            sendXHR="true"
                            uploadOnChange="false"
                            change="onFileChange"
                            uploadComplete="onUploadComplete"
                            buttonText="{i18n>uploadButton}" />

                        <Input id="_IDGenInput"
                            value="{chat>/question}"
                            placeholder="{i18n>questionPlaceholder}"
                            class="sapUiMediumMarginTop"
                            submit="onAsk" />

                        <Button id="_IDGenButton"
                            text="{i18n>askButton}"
                            type="Emphasized"
                            press="onAsk"
                            class="sapUiSmallMarginTop"
                            enabled="{= !${chat>/loading} }" />

                        <VBox id="_IDGenVBox2" class="sapUiMediumMarginTop">

                            <Title id="_IDGenTitle"
                                text="{i18n>assistantResponse}"
                                level="H5" />

                            <TextArea id="_IDGenTextArea"
                                value="{chat>/response}"
                                editable="false"
                                rows="20"
                                width="100%"
                                growing="true"
                                busy="{chat>/loading}" />

                        </VBox>

                    </VBox>

                </Panel>

            </VBox>

        </content>

    </Page>

</mvc:View>