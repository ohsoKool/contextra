<mvc:View
    controllerName="contextragen.ui.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified"
    displayBlock="true">

    <Page
        id="page"
        showHeader="false">

        <content>

            <VBox id="_IDGenVBox1"
                width="100%"
                alignItems="Center"
                justifyContent="Start"
                class="sapUiLargeMarginTop">

                <Panel id="_IDGenPanel"
                    width="900px"
                    headerText="{i18n>appTitle}"
                    class="sapUiResponsiveMargin">

                    <VBox id="_IDGenVBox2" class="sapUiMediumMargin">

                        <!-- PDF Upload -->

                        <unified:FileUploader
                            id="pdfUploader"
                            name="pdf"
                            uploadUrl="/upload"
                            fileType="pdf"
                            uploadOnChange="true"
                            buttonText="{i18n>uploadButton}"
                            uploadComplete="onUploadComplete"
                        />

                        <!-- Question Input -->

                        <Input id="_IDGenInput"
                            value="{chat>/question}"
                            placeholder="{i18n>questionPlaceholder}"
                            class="sapUiMediumMarginTop"
                            submit="onAsk"
                        />

                        <!-- Ask Button -->

                        <Button id="_IDGenButton"
                            text="{i18n>askButton}"
                            type="Emphasized"
                            press="onAsk"
                            class="sapUiSmallMarginTop"
                            enabled="{= !${chat>/loading} }"
                        />

                        <!-- AI Response -->

                        <VBox id="_IDGenVBox3" class="sapUiMediumMarginTop">

                            <Title id="_IDGenTitle"
                                text="{i18n>assistantResponse}"
                                level="H5"
                            />

                            <TextArea id="_IDGenTextArea"
                                value="{chat>/response}"
                                editable="false"
                                rows="20"
                                width="100%"
                                growing="true"
                                busy="{chat>/loading}"
                            />

                        </VBox>

                    </VBox>

                </Panel>

            </VBox>

        </content>

    </Page>

</mvc:View>